# ─────────────────────────────────────────────────────────────
# Incoterms LTI Tool — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to GitHub.
# ─────────────────────────────────────────────────────────────

# A long random secret string — generate one at: https://randomkeygen.com
LTI_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET

# MongoDB connection string
# On Railway: this is auto-provided when you add a MongoDB plugin
# Locally: mongodb://localhost:27017/lti-incoterm
DATABASE_URL=mongodb://localhost:27017/lti-incoterm

# Server port (Railway sets this automatically)
PORT=3000

# ─── Values provided by HBI's LMS Administrator ───────────────
# These are given to you after HBI registers your tool in their LMS

# The Issuer URL of HBI's LMS (e.g. https://hbi.instructure.com)
LTI_ISS=

# The Client ID assigned to your tool by HBI's LMS
LTI_CLIENT_ID=

# HBI LMS OIDC Authentication endpoint
LTI_AUTH_URL=

# HBI LMS Access Token endpoint
LTI_ACCESSTKN=

# HBI LMS Public Key Set URL (for JWT verification)
LTI_KEYSET_URL=

# Set to "production" when deploying live
NODE_ENV=production
